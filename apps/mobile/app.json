{
  "expo": {
    "name": "Flint",
    "slug": "flint",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "flint",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#FAF7F1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flint.app"
    },
    "android": {
      "package": "com.flint.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F1"
      }
    },
    "plugins": ["expo-router"]
  }
}

FROM golang:1.23-alpine AS builder
WORKDIR /src
COPY services/enrich/go.mod services/enrich/go.sum ./
RUN go mod download
COPY services/enrich/ .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /enrich ./cmd/enrich

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /enrich /usr/local/bin/enrich
COPY services/enrich/fixtures /fixtures
CMD ["enrich"]
